# Runtime artifacts
/var/
/bin/
/dist/

# TLS material (regenerated locally)
*.pem
*.key
*.crt
*.csr

# Live working plan — not a tracked artifact
/plan.md

# Go build output
/server
/client
/proxy
/fleet

# Local build/test cache (used during sandboxed go runs)
/.gocache/

# Editor/OS junk
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Compose / observability local state. The targets file is rewritten by the
# fleet on every start, so we don't track per-run contents — the directory
# stays via .gitkeep so the docker compose bind mount works on a fresh clone.
/deploy/targets/clients.json
/deploy/data/
