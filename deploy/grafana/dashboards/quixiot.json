      "targets": [{
        "refId": "A",
        "expr": "rate(quixiot_server_upload_bytes_sum[$__rate_interval])",
        "legendFormat": "bytes"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
