        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le, direction) (rate(quixiot_proxy_enforced_delay_seconds_bucket{direction=~\"$direction\"}[$__rate_interval])))", "legendFormat": "p95 {{direction}}"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le, direction) (rate(quixiot_proxy_enforced_delay_seconds_bucket{direction=~\"$direction\"}[$__rate_interval])))", "legendFormat": "p99 {{direction}}"}
