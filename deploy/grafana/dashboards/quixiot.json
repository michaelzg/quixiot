{
  "title": "QuixIoT — HTTP/3 + QUIC IoT PoC",
  "uid": "quixiot-overview",
  "tags": ["quixiot", "quic", "http3", "webtransport"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "fiscalYearStartMonth": 0,
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "prometheus"},
        "hide": 0
      },
      {
        "name": "client_id",
        "label": "Client",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(up{component=\"client\"}, client_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "topic",
        "label": "Topic",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(quixiot_client_datagrams_total, topic)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "direction",
        "label": "Direction",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(quixiot_proxy_packets_total, direction)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "At a glance",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Active QUIC connections",
      "description": "Server-side QUIC connections currently up.",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "quixiot_server_connections_active"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pubsub subscribers",
      "description": "Total subscriber slots across all topics.",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "sum(quixiot_server_pubsub_subscribers)"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active proxy sessions",
      "description": "NAT entries kept open by the impairment proxy.",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "quixiot_proxy_sessions_active"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reconnects (5m rate)",
      "description": "Should hover at 0 — non-zero means a client tore the QUIC connection down.",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "sum(rate(quixiot_client_reconnects_total[5m]))"}],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Drop rate to_server",
      "description": "Observed proxy drop rate inbound to the server (1m window).",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "100 * sum(rate(quixiot_proxy_dropped_total{direction=\"to_server\"}[1m])) / clamp_min(sum(rate(quixiot_proxy_packets_total{direction=\"to_server\"}[1m])), 1)"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Throughput",
      "description": "Bytes/sec across the proxy in both directions (1m window).",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "sum(rate(quixiot_proxy_bytes_total[1m]))"}],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 200,
      "type": "row",
      "title": "Network impairment",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Drop rate by direction",
      "description": "rate(drops) / rate(packets) per direction. Compare with the configured profile to see jitter.",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "100 * rate(quixiot_proxy_dropped_total{direction=~\"$direction\"}[$__rate_interval]) / clamp_min(rate(quixiot_proxy_packets_total{direction=~\"$direction\"}[$__rate_interval]), 1)",
        "legendFormat": "{{direction}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 12, "gradientMode": "opacity", "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11,
      "type": "heatmap",
      "title": "Enforced delay distribution",
      "description": "Latency + jitter the proxy adds per packet, per direction.",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (le) (rate(quixiot_proxy_enforced_delay_seconds_bucket{direction=~\"$direction\"}[$__rate_interval]))",
        "format": "heatmap",
        "legendFormat": "{{le}}"
      }],
      "options": {
        "calculate": false,
        "yAxis": {"unit": "s", "decimals": 3, "axisPlacement": "left"},
        "color": {"scheme": "Spectral", "mode": "scheme", "exponent": 0.5, "steps": 64, "reverse": false},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"show": true, "yHistogram": true},
        "legend": {"show": true},
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9}
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Packets/sec by direction",
      "description": "Stacked packet flow through the proxy.",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "rate(quixiot_proxy_packets_total{direction=~\"$direction\"}[$__rate_interval])",
        "legendFormat": "{{direction}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 50, "gradientMode": "none", "stacking": {"mode": "normal"}, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Drops / dupes / reorders rate",
      "description": "Per-direction impairment counters, per-second.",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "sum by(direction) (rate(quixiot_proxy_dropped_total{direction=~\"$direction\"}[$__rate_interval]))", "legendFormat": "drop {{direction}}"},
        {"refId": "B", "expr": "sum by(direction) (rate(quixiot_proxy_duplicated_total{direction=~\"$direction\"}[$__rate_interval]))", "legendFormat": "dup {{direction}}"},
        {"refId": "C", "expr": "sum by(direction) (rate(quixiot_proxy_reordered_total{direction=~\"$direction\"}[$__rate_interval]))", "legendFormat": "reorder {{direction}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean"]}}
    },

    {
      "id": 300,
      "type": "row",
      "title": "QUIC resilience",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 21, "w": 24, "h": 1}
    },
    {
      "id": 20,
      "type": "heatmap",
      "title": "Client handshake duration",
      "description": "Each client opens 2 QUIC connections at startup (H3 + WebTransport). Expect a single burst, then nothing — re-handshakes mean trouble.",
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (le) (rate(quixiot_client_handshake_duration_seconds_bucket{client_id=~\"$client_id\"}[$__rate_interval]))",
        "format": "heatmap",
        "legendFormat": "{{le}}"
      }],
      "options": {
        "calculate": false,
        "yAxis": {"unit": "s", "decimals": 3, "axisPlacement": "left"},
        "color": {"scheme": "Inferno", "mode": "scheme", "exponent": 0.5, "steps": 64},
        "tooltip": {"show": true, "yHistogram": true},
        "legend": {"show": true}
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "RTT (smoothed) per client",
      "description": "QUIC's reported smoothed RTT — should be stable through loss, not spiking.",
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "quixiot_client_rtt_seconds{client_id=~\"$client_id\"} * 1000",
        "legendFormat": "{{client_id}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1.5, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Handshakes vs reconnects (cumulative)",
      "description": "Handshakes count grows on connect; reconnects should stay flat at 0.",
      "gridPos": {"x": 0, "y": 30, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "sum(quixiot_client_handshake_duration_seconds_count{client_id=~\"$client_id\"})", "legendFormat": "handshakes"},
        {"refId": "B", "expr": "sum(quixiot_client_reconnects_total{client_id=~\"$client_id\"})", "legendFormat": "reconnects"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "reconnects"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Reconnects in selected range",
      "gridPos": {"x": 12, "y": 30, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"refId": "A", "expr": "sum(increase(quixiot_client_reconnects_total{client_id=~\"$client_id\"}[$__range]))"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Median handshake (s)",
      "gridPos": {"x": 18, "y": 30, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "histogram_quantile(0.5, sum by (le) (rate(quixiot_client_handshake_duration_seconds_bucket{client_id=~\"$client_id\"}[$__rate_interval])))"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 400,
      "type": "row",
      "title": "WebTransport pubsub",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 1}
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Datagrams in/out by topic",
      "description": "Datagram throughput on each WT session, split by direction (out=publisher, in=subscriber).",
      "gridPos": {"x": 0, "y": 38, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (direction, topic) (rate(quixiot_client_datagrams_total{client_id=~\"$client_id\", topic=~\"$topic\"}[$__rate_interval]))",
        "legendFormat": "{{direction}} {{topic}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1.5, "fillOpacity": 8, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Datagram round-trip loss % by topic",
      "description": "Computed: (out − in) / out. The headline contrast vs reliable streams.",
      "gridPos": {"x": 12, "y": 38, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "100 * (sum by (topic) (rate(quixiot_client_datagrams_total{direction=\"out\", topic=~\"$topic\"}[$__rate_interval])) - sum by (topic) (rate(quixiot_client_datagrams_total{direction=\"in\", topic=~\"$topic\"}[$__rate_interval]))) / clamp_min(sum by (topic) (rate(quixiot_client_datagrams_total{direction=\"out\", topic=~\"$topic\"}[$__rate_interval])), 1e-9)",
        "legendFormat": "{{topic}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Publish-to-receive latency p50/p95/p99",
      "description": "Subscriber timestamps each delivered message vs the publisher's stamped timestamp. Mixes datagram + stream surfaces.",
      "gridPos": {"x": 0, "y": 46, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(quixiot_client_publish_latency_seconds_bucket{client_id=~\"$client_id\"}[$__rate_interval])))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(quixiot_client_publish_latency_seconds_bucket{client_id=~\"$client_id\"}[$__rate_interval])))", "legendFormat": "p95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(quixiot_client_publish_latency_seconds_bucket{client_id=~\"$client_id\"}[$__rate_interval])))", "legendFormat": "p99"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1.5, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Pubsub drops by reason / surface",
      "description": "Server-side drops when a subscriber's outbound queue is full.",
      "gridPos": {"x": 12, "y": 46, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (surface, reason) (rate(quixiot_server_pubsub_drops_total[$__rate_interval]))",
        "legendFormat": "{{surface}} {{reason}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": {"mode": "normal"}, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}}
    },

    {
      "id": 500,
      "type": "row",
      "title": "HTTP/3 workload",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 54, "w": 24, "h": 1}
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Request rate by path",
      "description": "Server-side HTTP/3 requests per second by handler.",
      "gridPos": {"x": 0, "y": 55, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (method, path, status) (rate(quixiot_server_http_request_duration_seconds_count[$__rate_interval]))",
        "legendFormat": "{{method}} {{path}} → {{status}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1.5, "fillOpacity": 8, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean"]}}
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Server request latency p50/p95/p99",
      "gridPos": {"x": 12, "y": 55, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum by (le, path) (rate(quixiot_server_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50 {{path}}"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le, path) (rate(quixiot_server_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95 {{path}}"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le, path) (rate(quixiot_server_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99 {{path}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1.5, "fillOpacity": 0, "showPoints": "never"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Upload bytes/sec",
